# =========================
# Gradle
# =========================
.gradle/
build/

# Ignore Gradle caches but keep wrapper files
gradle/*
!gradle/wrapper/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Compiled output folders
bin/
*.class

# Bench / generated artifacts
results/
test-results/

# Logs
*.log

# OS
Thumbs.db
.DS_Store

# IDE
.idea/
.vscode/
*.iml

# Crash logs
hs_err_pid*
replay_pid*

# =========================
# Private course control docs
# =========================
/CONVENTIONS.md
/COURSE_TODO.md
/EXERCISES_TEMPLATE.md
/SYLLABUS_LAB_ALIGNMENT.md
/PITFALLS.md
/_template-week/

# =========================
# Lecture publishing
# =========================
# Do not publish LaTeX sources to the student repository.
# Commit the generated PDFs instead.
/Lectures/*.tex
!/Lectures/*.pdf

# LaTeX build byproducts
/Lectures/*.aux
/Lectures/*.bbl
/Lectures/*.bcf
/Lectures/*.blg
/Lectures/*.fdb_latexmk
/Lectures/*.fls
/Lectures/*.lof
/Lectures/*.log
/Lectures/*.lot
/Lectures/*.nav
/Lectures/*.out
/Lectures/*.run.xml
/Lectures/*.snm
/Lectures/*.synctex.gz
/Lectures/*.toc
/Lectures/*.vrb

# Internal planning/review docs (do not publish)
/WEEK5_COHERENCE_REVIEW.md
/LAB_MANUALS_STATUS.md
